# ========================
# ローカル開発用環境変数
# cp .env.example .env してから値を変更してください
# ========================

# Database (Docker PostgreSQL)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=next_practice_development

# Backend
SECRET_KEY_BASE=development_secret_key_base_please_change_in_production
JWT_SECRET=development_jwt_secret_please_change_in_production
RAILS_ENV=development
FRONTEND_ORIGIN=http://localhost:8000

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1
INTERNAL_API_URL=http://backend:3001/api/v1
